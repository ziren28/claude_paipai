[Unit]
Description=派派数字孪生备份（.claude projects + skills 打包上 R2）
After=network.target

[Service]
Type=oneshot
WorkingDirectory=/root/paipai
EnvironmentFile=/root/paipai/.env
ExecStart=/usr/bin/python3 /root/paipai/archive_claude.py
StandardOutput=append:/root/paipai/archive.log
StandardError=append:/root/paipai/archive.log
